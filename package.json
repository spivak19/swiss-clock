{
  "name": "swissclock",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev --port 8787 --proxy 5199 -- npm run dev",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=swissclock",
    "kv:create": "wrangler kv namespace create ATTENDANCE_KV",
    "kv:create:preview": "wrangler kv namespace create ATTENDANCE_KV --preview",
    "wrangler:types": "wrangler types --path=\"./functions/types.d.ts\""
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240712.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wrangler": "^3.63.1"
  }
}
